{
  "name": "koban-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.35"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "proseWrap": "always",
    "printWidth": 80,
    "overrides": [
      {
        "files": "**/*.md",
        "options": {
          "proseWrap": "preserve"
        }
      }
    ]
  }
}
